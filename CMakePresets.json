      "cacheVariables": {
        "PICLAS_EQNSYSNAME":     "maxwell",
        "PICLAS_TIMEDISCMETHOD": "RK3"
      }
    },
    {
      "name": "windows-maxwell-radiation-mpi-gpu",
      "displayName": "Windows - maxwell + Radiation + MPI + GPU",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-maxwell-radiation-mpi-gpu",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":        "maxwell",
