    {
      "name": "windows-maxwell-dsmc-release-mpi-gpu",
      "displayName": "Windows - maxwell + DSMC + MPI + GPU (AgNozzle build)",
      "description": "DSMC + MPI + GPU push (the binary used for the 2D-axisymmetric silver-vapor nozzle case at C:\\Data\\PRJ\\AgNozzle). Requires CUDA Toolkit + MSVC cl.exe (auto-found by SetGPU.cmake). PICLAS_UNITTESTS=OFF — with CUDA enabled the test executables race against mod_globals.mod; piclas itself does not need them.",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-maxwell-dsmc-release-mpi-gpu",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":        "maxwell",
        "PICLAS_TIMEDISCMETHOD":    "DSMC",
        "PICLAS_USE_GPU":           "ON",
        "CMAKE_CUDA_ARCHITECTURES": "75-real;86-real;89-real;90-virtual",
        "CMAKE_CUDA_COMPILER":      "nvcc",
        "PICLAS_UNITTESTS":         "OFF"
      }
    },
    {
      "name": "windows-maxwell-dsmc-release-mpi-posti",
      "displayName": "Windows - maxwell + DSMC + MPI + POSTI (piclas2vtk build)",
      "description": "DSMC + MPI + POSTI tools (piclas2vtk).  Same equation/timedisc as the AgNozzle DSMC build so the resulting piclas2vtk can post-process State / DSMCState / PartStateBoundary files from that run.",
