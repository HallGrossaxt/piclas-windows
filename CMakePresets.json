{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "windows-ucrt64-poisson",
      "displayName": "Windows MSYS2 UCRT64 - Poisson/RK3 (plasma wave tutorial)",
      "description": "Poisson solver (HDGSEM) + RK3 time integration, required for pic-poisson-plasma-wave tutorial",
      "inherits": "windows-ucrt64",
      "binaryDir": "${sourceDir}/build-ucrt64-poisson",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":     "poisson",
        "PICLAS_TIMEDISCMETHOD": "RK3",
        "PICLAS_UNITTESTS":      "OFF",
        "PICLAS_BUILD_POSTI":    "ON"
      }
    },
    {
      "name": "windows-ucrt64",
      "displayName": "Windows MSYS2 UCRT64 (Release)",
      "description": "Build PICLas on Windows using MSYS2 UCRT64 toolchain (gfortran 15, HDF5 2.1.0, Ninja)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-ucrt64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE":       "Release",
        "CMAKE_C_COMPILER":       "C:/msys64/ucrt64/bin/gcc.exe",
        "CMAKE_CXX_COMPILER":     "C:/msys64/ucrt64/bin/g++.exe",
        "CMAKE_Fortran_COMPILER": "C:/msys64/ucrt64/bin/gfortran.exe",
        "CMAKE_MAKE_PROGRAM":     "C:/msys64/ucrt64/bin/ninja.exe",
        "CMAKE_PREFIX_PATH":      "C:/msys64/ucrt64",
        "HDF5_ROOT":              "C:/msys64/ucrt64",
        "HDF5_DIR":               "C:/msys64/ucrt64/lib/cmake/hdf5",
        "LIBS_BUILD_HDF5":        "OFF",
        "HDF5_Fortran_INCLUDE_DIR": "C:/msys64/ucrt64/include",
        "LIBS_USE_MPI":           "OFF",
        "LIBS_BUILD_MATH_LIB":    "OFF",
        "LAPACK_ROOT":            "C:/msys64/ucrt64",
        "PICLAS_BUILD_POSTI":     "OFF",
        "PICLAS_IPO":             "OFF",
        "PICLAS_INSTRUCTION":     "-march=x86-64-v2 -mtune=generic"
      },
      "environment": {
        "PATH": "C:/msys64/ucrt64/bin;C:/msys64/usr/bin;$penv{PATH}"
      }
    },
    {
      "name": "windows-ucrt64-mpi",
      "displayName": "Windows MSYS2 UCRT64 + MS-MPI (Release)",
      "description": "MPI-enabled build using MSYS2 UCRT64 toolchain and Microsoft MPI (mingw-w64-ucrt-x86_64-msmpi)",
      "inherits": "windows-ucrt64",
      "binaryDir": "${sourceDir}/build-ucrt64-mpi",
      "cacheVariables": {
        "LIBS_USE_MPI":           "ON",
        "MPI_HOME":               "C:/msys64/ucrt64",
        "MPI_C_COMPILER":         "C:/msys64/ucrt64/bin/mpicc",
        "MPI_CXX_COMPILER":       "C:/msys64/ucrt64/bin/mpicxx",
        "MPI_Fortran_COMPILER":   "C:/msys64/ucrt64/bin/mpifort"
      }
    },
    {
      "name": "windows-ucrt64-debug",
      "displayName": "Windows MSYS2 UCRT64 (Debug)",
      "description": "Debug build of PICLas on Windows using MSYS2 UCRT64",
      "inherits": "windows-ucrt64",
      "binaryDir": "${sourceDir}/build-ucrt64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "windows-ucrt64-gpu",
      "displayName": "Windows MSYS2 UCRT64 + CUDA GPU (Release)",
      "description": "GPU-accelerated build: CUDA kernels compiled by nvcc, Fortran via ISO_C_BINDING. Requires NVIDIA GPU + CUDA Toolkit 12.x on PATH.",
      "inherits": "windows-ucrt64",
      "binaryDir": "${sourceDir}/build-ucrt64-gpu",
      "cacheVariables": {
        "PICLAS_USE_GPU":            "ON",
        "CMAKE_CUDA_ARCHITECTURES":  "86",
        "CMAKE_CUDA_COMPILER":       "nvcc"
      }
    },
    {
      "name": "windows-ucrt64-superB",
      "displayName": "Windows MSYS2 UCRT64 - superB magnetic field pre-processor",
      "description": "Builds the superB standalone tool for computing coil and permanent-magnet B-fields on a mesh. Output HDF5 background-field file is loaded by subsequent PICLas simulations.",
      "inherits": "windows-ucrt64",
      "binaryDir": "${sourceDir}/build-ucrt64-superB",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":     "maxwell",
        "PICLAS_TIMEDISCMETHOD": "RK4",
        "PICLAS_BUILD_POSTI":    "ON",
        "PICLAS_UNITTESTS":      "OFF"
      }
    },
    {
      "name": "windows-maxwell-bgk-mpi-gpu",
      "displayName": "Windows - maxwell + BGK-Flow + MPI + GPU",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-maxwell-bgk-mpi-gpu",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":        "maxwell",
        "PICLAS_TIMEDISCMETHOD":    "BGK-Flow",
        "PICLAS_USE_GPU":           "ON",
        "CMAKE_CUDA_ARCHITECTURES": "86",
        "CMAKE_CUDA_COMPILER":      "nvcc"
      }
    },
    {
      "name": "windows-maxwell-rk4-mpi-gpu",
      "displayName": "Windows - maxwell + RK4 + MPI + GPU",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-maxwell-rk4-mpi-gpu",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":        "maxwell",
        "PICLAS_TIMEDISCMETHOD":    "RK4",
        "PICLAS_USE_GPU":           "ON",
        "CMAKE_CUDA_ARCHITECTURES": "86",
        "CMAKE_CUDA_COMPILER":      "nvcc"
      }
    },
    {
      "name": "windows-maxwell-rk3-mpi",
      "displayName": "Windows - maxwell + RK3 + MPI",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-maxwell-rk3-mpi",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":     "maxwell",
        "PICLAS_TIMEDISCMETHOD": "RK3"
      }
    },
    {
      "name": "windows-maxwell-radiation-mpi-gpu",
      "displayName": "Windows - maxwell + Radiation + MPI + GPU",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-maxwell-radiation-mpi-gpu",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":        "maxwell",
        "PICLAS_TIMEDISCMETHOD":    "Radiation",
        "PICLAS_USE_GPU":           "ON",
        "CMAKE_CUDA_ARCHITECTURES": "86",
        "CMAKE_CUDA_COMPILER":      "nvcc"
      }
    },
    {
      "name": "windows-maxwell-superb-mpi",
      "displayName": "Windows - maxwell + RK3 + MPI + SuperB POSTI",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-maxwell-superb-mpi",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":     "maxwell",
        "PICLAS_TIMEDISCMETHOD": "RK3",
        "PICLAS_BUILD_POSTI":    "ON",
        "POSTI_BUILD_SUPERB":    "ON"
      }
    },
    {
      "name": "windows-maxwell-rk4-dmd-mpi",
      "displayName": "Windows - maxwell + RK4 + DMD + MPI (no particles)",
      "description": "PARTICLES=OFF build with DMD and piclas2vtk POSTI tools. Required by NIG_maxwell_RK4 (builds.ini: PICLAS_PARTICLES=OFF, POSTI_BUILD_DMD=ON).",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-maxwell-rk4-dmd-mpi",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":     "maxwell",
        "PICLAS_TIMEDISCMETHOD": "RK4",
        "PICLAS_PARTICLES":      "OFF",
        "PICLAS_BUILD_POSTI":    "ON",
        "POSTI_BUILD_DMD":       "ON",
        "POSTI_BUILD_SUPERB":    "OFF",
        "PICLAS_UNITTESTS":      "OFF"
      }
    },
    {
      "name": "windows-edvm-mpi",
      "displayName": "Windows - discrete_velocity + ED-DVM + MPI",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-edvm-mpi",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":     "discrete_velocity",
        "PICLAS_TIMEDISCMETHOD": "ED-DVM",
        "PICLAS_FV_2D":          "ON",
        "PICLAS_PARTICLES":      "OFF"
      }
    },
    {
      "name": "windows-poisson-leapfrog-mpi-gpu",
      "displayName": "Windows - poisson + Leapfrog + MPI + GPU",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-poisson-leapfrog-mpi-gpu",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":        "poisson",
        "PICLAS_TIMEDISCMETHOD":    "Leapfrog",
        "PICLAS_USE_GPU":           "ON",
        "CMAKE_CUDA_ARCHITECTURES": "86",
        "CMAKE_CUDA_COMPILER":      "nvcc"
      }
    },
    {
      "name": "windows-poisson-boris-mpi-gpu",
      "displayName": "Windows - poisson + Boris-Leapfrog + MPI + GPU",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-poisson-boris-mpi-gpu",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":        "poisson",
        "PICLAS_TIMEDISCMETHOD":    "Boris-Leapfrog",
        "PICLAS_USE_GPU":           "ON",
        "CMAKE_CUDA_ARCHITECTURES": "86",
        "CMAKE_CUDA_COMPILER":      "nvcc"
      }
    },
    {
      "name": "windows-poisson-rk3-mpi-gpu",
      "displayName": "Windows - poisson + RK3 + MPI + GPU",
      "inherits": "windows-ucrt64-mpi",
      "binaryDir": "${sourceDir}/build-poisson-rk3-mpi-gpu",
      "cacheVariables": {
        "PICLAS_EQNSYSNAME":        "poisson",
        "PICLAS_TIMEDISCMETHOD":    "RK3",
        "PICLAS_USE_GPU":           "ON",
        "CMAKE_CUDA_ARCHITECTURES": "86",
        "CMAKE_CUDA_COMPILER":      "nvcc"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-ucrt64-poisson",
      "configurePreset": "windows-ucrt64-poisson",
      "jobs": 0
    },
    {
      "name": "windows-ucrt64",
      "configurePreset": "windows-ucrt64",
      "jobs": 0
    },
    {
      "name": "windows-ucrt64-mpi",
      "configurePreset": "windows-ucrt64-mpi",
      "jobs": 0
