      "configurePreset": "windows-ucrt64-superB",
      "jobs": 0
    },
    {
      "name": "windows-maxwell-bgk-mpi-gpu",
      "configurePreset": "windows-maxwell-bgk-mpi-gpu",
      "jobs": 0
    },
    {
      "name": "windows-maxwell-rk4-mpi-gpu",
      "configurePreset": "windows-maxwell-rk4-mpi-gpu",
      "jobs": 0
    },
    {
      "name": "windows-maxwell-rk3-mpi",
      "configurePreset": "windows-maxwell-rk3-mpi",
      "jobs": 0
    },
    {
      "name": "windows-maxwell-radiation-mpi-gpu",
      "configurePreset": "windows-maxwell-radiation-mpi-gpu",
      "jobs": 0
    },
    {
      "name": "windows-maxwell-superb-mpi",
      "configurePreset": "windows-maxwell-superb-mpi",
      "jobs": 0
    },
    {
      "name": "windows-maxwell-rk4-dmd-mpi",
      "configurePreset": "windows-maxwell-rk4-dmd-mpi",
      "jobs": 0
    },
    {
      "name": "windows-edvm-mpi",
      "configurePreset": "windows-edvm-mpi",
      "jobs": 0
    },
    {
      "name": "windows-poisson-leapfrog-mpi-gpu",
      "configurePreset": "windows-poisson-leapfrog-mpi-gpu",
      "jobs": 0
    },
    {
      "name": "windows-poisson-boris-mpi-gpu",
      "configurePreset": "windows-poisson-boris-mpi-gpu",
      "jobs": 0
    },
    {
      "name": "windows-poisson-rk3-mpi-gpu",
      "configurePreset": "windows-poisson-rk3-mpi-gpu",
      "jobs": 0
    }
  ]
}
